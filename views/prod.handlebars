<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Tienda Cool - Editor de Productos</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" type="text/css" href="/css/NewProd.css">
</head>
<body>
    <div class="container-fluid hero-section text-center">  
        <div class="hero-text">
            <h2>Editor de Productos</h2>
        </div>
    </div>
    
    <div class="container text-center mt-5">
        <div class="row align-items-center">
            <div class="col">
                <form action="/products" method="POST" enctype="multipart/form-data">
                    <div class="row g-4 align-items-center">
                        <div class="col-5">
                            <label for="Imagen" class="form-label">
                                <img src="/Imagenes/logo.png" width="50%" height="50%">
                            </label>
                            <input name="foto" type="file" class="form-control" id="Imagen" placeholder="Foto">
                        </div>
                        <div class="col-3">
                            <label for="Nombre" class="form-label">Nombre de producto</label>
                            <input type="text" class="form-control" id="Nombre" name="name" placeholder="Nombre de producto" required>
                            
                            <label for="Categoria" class="form-label">Categoría</label>
                            <select id="Categoria" class="form-select" name="categ" required>
                                <option selected>Selecciona la categoría</option>
                                <option>Réplicas</option>
                                <option>Accesorios</option>
                                <option>Equipamiento</option>
                                <option>Repuestos</option>
                            </select>
                        </div>
                        <div class="col-3">
                            <label for="Descripcion-base" class="form-label">Descripción Básica</label>
                            <input type="text" class="form-control" id="Descripcion-base" name="db" placeholder="Descripción Básica" required>
                            
                            <label for="Precio" class="form-label">Precio</label>
                            <input type="text" class="form-control" id="Precio" name="price" placeholder="Precio" required>
                        </div>
                        <div class="col">
                            <label for="Descripcion" class="form-label">Descripción Completa</label>
                            <input type="text" class="form-control" id="Descripcion" name="descr" placeholder="Descripción Completa" required>
                        </div>
                        <div class="col">
                            <label for="Destacado" class="form-label">¿Producto Destacado?</label>
                            <input type="checkbox" class="form-check-input" id="Destacado" name="destacado">
                        </div>
                        <div class="col-12 mt-3">
                            <button type="submit" class="btn btn-primary">Ingresar Producto</button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</body>
</html>
